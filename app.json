{
  "expo": {
    "name": "expense-subscription-tracker",
    "slug": "expense-subscription-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "expensesubscriptiontracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.expense.tracker.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1d143457-68b6-44c2-a20c-d62ded7baed5"
      }
    }
  }
}
